{
  "name": "xfbrowser",
  "version": "1.2.0-release",
  "description": "XFbrowser – Where simple browsing shines",
  "keywords": [
    "XFBrowser",
    "Browser",
    "xuanfeng0316",
    "XF",
    "Zhouyi",
    "YaoZhouyi",
    "ZhouyiStudio"
  ],
  "homepage": "https://github.com/ZhouyiStudio/XFBrowser-Desktop#readme",
  "bugs": {
    "url": "https://github.com/ZhouyiStudio/XFBrowser-Desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZhouyiStudio/XFBrowser-Desktop.git"
  },
  "license": "Apache-2.0",
  "author": "ZhouyiStudio",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --publish=never",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.32"
  },
  "build": {
    "appId": "com.zhouyistudio.xfbrowser",
    "productName": "XFBrowser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!build/**/*",
      "!*.md",
      "!package-lock.json",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}